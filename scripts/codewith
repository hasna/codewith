#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "${source}" ]]; do
    local dir
    dir="$(cd -P "$(dirname "${source}")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "${source}")"
    [[ "${source}" == /* ]] || source="${dir}/${source}"
  done
  cd -P "$(dirname "${source}")" >/dev/null 2>&1 && pwd
}

find_codewith_bin() {
  local script_dir="$1"

  if [[ -n "${CODEWITH_BIN:-}" ]]; then
    printf '%s\n' "${CODEWITH_BIN}"
    return 0
  fi

  local candidate
  for candidate in \
    "${script_dir}/codewith-bin" \
    "${script_dir}/../codex-rs/target/debug/codex" \
    "${script_dir}/../codex-rs/target/release/codex"; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done

  return 1
}

main() {
  local script_dir
  script_dir="$(resolve_script_dir)"

  local codewith_bin
  if ! codewith_bin="$(find_codewith_bin "${script_dir}")"; then
    printf 'codewith: unable to find the Codewith binary. Set CODEWITH_BIN to its path.\n' >&2
    return 127
  fi

  if [[ -n "${CODEWITH_HOME:-}" ]]; then
    export CODEX_HOME="${CODEWITH_HOME}"
  else
    export CODEX_HOME="${CODEX_HOME:-${HOME}/.codewith}"
    export CODEWITH_HOME="${CODEX_HOME}"
  fi
  mkdir -p -m 700 "${CODEX_HOME}"
  chmod go-rwx "${CODEX_HOME}" 2>/dev/null || true

  exec "${codewith_bin}" "$@"
}

main "$@"
