{
  "$defs": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not\nguaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set\nusing [AbsolutePathBufGuard::new]. If no base path is set, the\ndeserialization will fail unless the path being deserialized is already\nabsolute.",
      "type": "string"
    },
    "AdditionalFileSystemPermissions": {
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/FileSystemSandboxEntry"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "globScanMaxDepth": {
          "format": "uint",
          "minimum": 1,
          "type": [
            "integer",
            "null"
          ]
        },
        "read": {
          "description": "This will be removed in favor of `entries`.",
          "items": {
            "$ref": "#/$defs/AbsolutePathBuf"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "write": {
          "description": "This will be removed in favor of `entries`.",
          "items": {
            "$ref": "#/$defs/AbsolutePathBuf"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AdditionalNetworkPermissions": {
      "properties": {
        "enabled": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "CommandExecutionApprovalDecision": {
      "oneOf": [
        {
          "const": "accept",
          "description": "User approved the command.",
          "type": "string"
        },
        {
          "const": "acceptForSession",
          "description": "User approved the command and future prompts in the same session-scoped\napproval cache should run without prompting.",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "description": "User approved the command, and wants to apply the proposed execpolicy amendment so future\nmatching commands can run without prompting.",
          "properties": {
            "acceptWithExecpolicyAmendment": {
              "properties": {
                "execpolicy_amendment": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "required": [
                "execpolicy_amendment"
              ],
              "type": "object"
            }
          },
          "required": [
            "acceptWithExecpolicyAmendment"
          ],
          "title": "AcceptWithExecpolicyAmendmentCommandExecutionApprovalDecision",
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "User chose a persistent network policy rule (allow/deny) for this host.",
          "properties": {
            "applyNetworkPolicyAmendment": {
              "properties": {
                "network_policy_amendment": {
                  "$ref": "#/$defs/NetworkPolicyAmendment"
                }
              },
              "required": [
                "network_policy_amendment"
              ],
              "type": "object"
            }
          },
          "required": [
            "applyNetworkPolicyAmendment"
          ],
          "title": "ApplyNetworkPolicyAmendmentCommandExecutionApprovalDecision",
          "type": "object"
        },
        {
          "const": "decline",
          "description": "User denied the command. The agent will continue the turn.",
          "type": "string"
        },
        {
          "const": "cancel",
          "description": "User denied the command. The turn will also be immediately interrupted.",
          "type": "string"
        }
      ]
    },
    "DynamicToolCallOutputContentItem": {
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "const": "inputText",
              "title": "InputTextDynamicToolCallOutputContentItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "title": "InputTextDynamicToolCallOutputContentItem",
          "type": "object"
        },
        {
          "properties": {
            "imageUrl": {
              "type": "string"
            },
            "type": {
              "const": "inputImage",
              "title": "InputImageDynamicToolCallOutputContentItemType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "imageUrl"
          ],
          "title": "InputImageDynamicToolCallOutputContentItem",
          "type": "object"
        }
      ]
    },
    "FileChangeApprovalDecision": {
      "oneOf": [
        {
          "const": "accept",
          "description": "User approved the file changes.",
          "type": "string"
        },
        {
          "const": "acceptForSession",
          "description": "User approved the file changes and future changes to the same files should run without prompting.",
          "type": "string"
        },
        {
          "const": "decline",
          "description": "User denied the file changes. The agent will continue the turn.",
          "type": "string"
        },
        {
          "const": "cancel",
          "description": "User denied the file changes. The turn will also be immediately interrupted.",
          "type": "string"
        }
      ]
    },
    "FileSystemAccessMode": {
      "enum": [
        "read",
        "write",
        "deny"
      ],
      "type": "string"
    },
    "FileSystemPath": {
      "oneOf": [
        {
          "properties": {
            "path": {
              "$ref": "#/$defs/AbsolutePathBuf"
            },
            "type": {
              "const": "path",
              "title": "PathFileSystemPathType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "path"
          ],
          "title": "PathFileSystemPath",
          "type": "object"
        },
        {
          "properties": {
            "pattern": {
              "type": "string"
            },
            "type": {
              "const": "glob_pattern",
              "title": "GlobPatternFileSystemPathType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "pattern"
          ],
          "title": "GlobPatternFileSystemPath",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "special",
              "title": "SpecialFileSystemPathType",
              "type": "string"
            },
            "value": {
              "$ref": "#/$defs/FileSystemSpecialPath"
            }
          },
          "required": [
            "type",
            "value"
          ],
          "title": "SpecialFileSystemPath",
          "type": "object"
        }
      ]
    },
    "FileSystemSandboxEntry": {
      "properties": {
        "access": {
          "$ref": "#/$defs/FileSystemAccessMode"
        },
        "path": {
          "$ref": "#/$defs/FileSystemPath"
        }
      },
      "required": [
        "path",
        "access"
      ],
      "type": "object"
    },
    "FileSystemSpecialPath": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "const": "root",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "RootFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "minimal",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "MinimalFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "project_roots",
              "type": "string"
            },
            "subpath": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ],
          "title": "KindFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "tmpdir",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "TmpdirFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "slash_tmp",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "title": "SlashTmpFileSystemSpecialPath",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "const": "unknown",
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "subpath": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "GrantedPermissionProfile": {
      "properties": {
        "fileSystem": {
          "anyOf": [
            {
              "$ref": "#/$defs/AdditionalFileSystemPermissions"
            },
            {
              "type": "null"
            }
          ]
        },
        "network": {
          "anyOf": [
            {
              "$ref": "#/$defs/AdditionalNetworkPermissions"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "McpServerElicitationAction": {
      "enum": [
        "accept",
        "decline",
        "cancel"
      ],
      "type": "string"
    },
    "NetworkPolicyAmendment": {
      "properties": {
        "action": {
          "$ref": "#/$defs/NetworkPolicyRuleAction"
        },
        "host": {
          "type": "string"
        }
      },
      "required": [
        "host",
        "action"
      ],
      "type": "object"
    },
    "NetworkPolicyRuleAction": {
      "enum": [
        "allow",
        "deny"
      ],
      "type": "string"
    },
    "PermissionGrantScope": {
      "enum": [
        "turn",
        "session"
      ],
      "type": "string"
    },
    "ThreadPendingInteractionResponsePayload": {
      "oneOf": [
        {
          "properties": {
            "decision": {
              "$ref": "#/$defs/CommandExecutionApprovalDecision"
            },
            "type": {
              "const": "commandApproval",
              "title": "CommandApprovalThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "decision"
          ],
          "title": "CommandApprovalThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "decision": {
              "$ref": "#/$defs/FileChangeApprovalDecision"
            },
            "type": {
              "const": "fileChangeApproval",
              "title": "FileChangeApprovalThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "decision"
          ],
          "title": "FileChangeApprovalThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "answers": {
              "additionalProperties": {
                "$ref": "#/$defs/ToolRequestUserInputAnswer"
              },
              "type": "object"
            },
            "type": {
              "const": "requestUserInput",
              "title": "RequestUserInputThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "answers"
          ],
          "title": "RequestUserInputThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "action": {
              "$ref": "#/$defs/McpServerElicitationAction"
            },
            "content": true,
            "meta": true,
            "type": {
              "const": "mcpElicitation",
              "title": "McpElicitationThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "action"
          ],
          "title": "McpElicitationThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "permissions": {
              "$ref": "#/$defs/GrantedPermissionProfile"
            },
            "scope": {
              "$ref": "#/$defs/PermissionGrantScope"
            },
            "strictAutoReview": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "type": {
              "const": "permissionsApproval",
              "title": "PermissionsApprovalThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "permissions",
            "scope"
          ],
          "title": "PermissionsApprovalThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "contentItems": {
              "items": {
                "$ref": "#/$defs/DynamicToolCallOutputContentItem"
              },
              "type": "array"
            },
            "success": {
              "type": "boolean"
            },
            "type": {
              "const": "dynamicTool",
              "title": "DynamicToolThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "contentItems",
            "success"
          ],
          "title": "DynamicToolThreadPendingInteractionResponsePayload",
          "type": "object"
        },
        {
          "properties": {
            "reason": {
              "type": "string"
            },
            "type": {
              "const": "terminal",
              "title": "TerminalThreadPendingInteractionResponsePayloadType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "reason"
          ],
          "title": "TerminalThreadPendingInteractionResponsePayload",
          "type": "object"
        }
      ]
    },
    "ThreadPendingInteractionTerminalStatus": {
      "enum": [
        "responded",
        "expired",
        "cancelled",
        "denied",
        "noLongerWaiting"
      ],
      "type": "string"
    },
    "ToolRequestUserInputAnswer": {
      "description": "EXPERIMENTAL. Captures a user's answer to a request_user_input question.",
      "properties": {
        "answers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "answers"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "dryRun": {
      "type": "boolean"
    },
    "interactionId": {
      "type": "string"
    },
    "response": {
      "$ref": "#/$defs/ThreadPendingInteractionResponsePayload"
    },
    "terminalStatus": {
      "$ref": "#/$defs/ThreadPendingInteractionTerminalStatus"
    },
    "threadId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "interactionId",
    "terminalStatus",
    "response"
  ],
  "title": "MissionControlRespondInteractionParams",
  "type": "object"
}