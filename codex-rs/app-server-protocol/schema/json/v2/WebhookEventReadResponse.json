        },
        "subscriptionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "targetThreadId": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
