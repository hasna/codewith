            "string",
            "null"
          ]
        },
        "idempotencyKey": {
          "type": [
            "string",
            "null"
          ]
        },
        "payloadPreview": {
          "type": "string"
        },
        "payloadSha256": {
          "type": "string"
        },
        "receivedAt": {
