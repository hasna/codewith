{
  "$defs": {
    "ThreadSchedule": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "expiresAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "failureCount": {
          "format": "int64",
          "type": "integer"
        },
        "lastRunAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "leaseExpiresAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "nestingDepth": {
          "format": "int64",
          "type": "integer"
        },
        "nextRunAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "parentScheduleId": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "promptSource": {
          "$ref": "#/$defs/ThreadSchedulePromptSource"
        },
        "schedule": {
          "$ref": "#/$defs/ThreadScheduleSpec"
        },
        "scheduleId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ThreadScheduleStatus"
        },
        "threadId": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "threadId",
        "scheduleId",
        "nestingDepth",
        "prompt",
        "promptSource",
        "schedule",
        "timezone",
        "status",
        "failureCount",
        "createdAt",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadScheduleIntervalUnit": {
      "enum": [
        "minutes",
        "hours",
        "days"
      ],
      "type": "string"
    },
    "ThreadSchedulePromptSource": {
      "enum": [
        "inline",
        "default"
      ],
      "type": "string"
    },
    "ThreadScheduleSpec": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "once",
              "title": "OnceThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "OnceThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "dynamic",
              "title": "DynamicThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DynamicThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "amount": {
              "format": "int64",
              "type": "integer"
            },
            "type": {
              "const": "interval",
              "title": "IntervalThreadScheduleSpecType",
              "type": "string"
            },
            "unit": {
              "$ref": "#/$defs/ThreadScheduleIntervalUnit"
            }
          },
          "required": [
            "type",
            "amount",
            "unit"
          ],
          "title": "IntervalThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "expression": {
              "type": "string"
            },
            "type": {
              "const": "cron",
              "title": "CronThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "expression"
          ],
          "title": "CronThreadScheduleSpec",
          "type": "object"
        }
      ]
    },
    "ThreadScheduleStatus": {
      "enum": [
        "active",
        "paused",
        "expired"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "schedule": {
      "$ref": "#/$defs/ThreadSchedule"
    }
  },
  "required": [
    "schedule"
  ],
  "title": "ThreadScheduleUpdateResponse",
  "type": "object"
}