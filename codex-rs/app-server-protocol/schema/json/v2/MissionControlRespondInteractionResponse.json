    "ThreadPendingInteractionKind": {
      "enum": [
        "commandApproval",
        "fileChangeApproval",
        "userInput",
        "mcpElicitation",
        "permissionGrant",
        "dynamicTool",
        "usageLimit",
        "profileSwitch",
        "blocked"
      ],
      "type": "string"
    },
    "ThreadPendingInteractionSourceKind": {
      "enum": [
        "thread",
        "backgroundAgent",
        "goal",
        "usageProfile"
      ],
      "type": "string"
    },
    "ThreadPendingInteractionStatus": {
      "enum": [
        "pending",
        "delivered",
        "responded",
        "expired",
        "cancelled",
        "denied",
        "noLongerWaiting"
      ],
      "type": "string"
    }
