        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "deliveredAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "interactionId": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/ThreadPendingInteractionKind"
        },
        "noClientPolicy": {
          "type": "string"
        },
        "requestPayload": true,
        "requestPayloadPreview": {
          "type": "string"
        },
        "requestPayloadSha256": {
          "type": "string"
        },
        "requestRedactions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "respondedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "responsePayload": true,
        "responsePayloadPreview": {
          "type": [
            "string",
            "null"
          ]
        },
        "responsePayloadSha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "responseRedactions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sourceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourceKind": {
          "$ref": "#/definitions/ThreadPendingInteractionSourceKind"
        },
        "status": {
          "$ref": "#/definitions/ThreadPendingInteractionStatus"
        },
        "terminalAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "threadId": {
          "type": "string"
        },
        "timeoutAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "turnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "workerRequestId": {
          "type": [
            "string",
            "null"
          ]
        }
