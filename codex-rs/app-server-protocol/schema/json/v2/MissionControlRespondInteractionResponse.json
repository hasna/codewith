      "required": [
        "createdAt",
        "interactionId",
        "kind",
        "noClientPolicy",
        "requestPayload",
        "requestPayloadPreview",
        "requestPayloadSha256",
        "requestRedactions",
        "responseRedactions",
        "sourceKind",
        "status",
        "threadId",
        "updatedAt"
      ],
      "type": "object"
