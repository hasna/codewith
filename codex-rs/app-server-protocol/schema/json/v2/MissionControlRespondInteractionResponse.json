  "properties": {
    "dryRun": {
      "type": "boolean"
    },
    "interaction": {
      "anyOf": [
        {
          "$ref": "#/definitions/ThreadPendingInteraction"
        },
        {
          "type": "null"
        }
      ]
    },
    "updated": {
      "type": "boolean"
    }
  },
  "required": [
    "dryRun",
    "updated"
  ],
  "title": "MissionControlRespondInteractionResponse",
  "type": "object"
