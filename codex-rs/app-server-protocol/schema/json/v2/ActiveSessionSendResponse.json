{
  "$defs": {
    "ActiveSessionSendStatus": {
      "enum": [
        "delivered",
        "notLoaded",
        "unsupported"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "messageId": {
      "description": "App-server-generated id for this active delivery attempt. It is not a\ndurable mailbox id or read receipt.",
      "type": "string"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "senderThreadId": {
      "description": "Echoes the claimed sender_thread_id when present and valid.",
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "$ref": "#/$defs/ActiveSessionSendStatus"
    },
    "targetPeerId": {
      "default": "",
      "type": "string"
    },
    "targetThreadId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "status",
    "messageId"
  ],
  "title": "ActiveSessionSendResponse",
  "type": "object"
}