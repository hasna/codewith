{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ActiveSessionSendStatus": {
      "enum": [
        "delivered",
        "notLoaded",
        "unsupported"
      ],
      "type": "string"
    }
  },
  "properties": {
    "messageId": {
      "description": "App-server-generated id for this active delivery attempt. It is not a durable mailbox id or read receipt.",
      "type": "string"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "senderThreadId": {
      "description": "Echoes the claimed sender_thread_id when present and valid.",
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "$ref": "#/definitions/ActiveSessionSendStatus"
    },
    "targetPeerId": {
      "default": "",
      "type": "string"
    },
    "targetThreadId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "messageId",
    "status"
  ],
  "title": "ActiveSessionSendResponse",
  "type": "object"
}