{
  "$defs": {
    "ThreadExternalAgentCloudArtifact": {
      "description": "Durable artifact surfaced by a cloud external-agent run.",
      "properties": {
        "label": {
          "type": "string"
        },
        "mimeType": {
          "type": [
            "string",
            "null"
          ]
        },
        "uri": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "label"
      ],
      "type": "object"
    },
    "ThreadExternalAgentCloudState": {
      "description": "Lifecycle state of a cloud (hosted) external-agent run.",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed",
        "cancelled"
      ],
      "type": "string"
    },
    "ThreadExternalAgentEvent": {
      "oneOf": [
        {
          "properties": {
            "mode": {
              "$ref": "#/$defs/ThreadExternalAgentMode"
            },
            "runtime_id": {
              "type": "string"
            },
            "task": {
              "type": "string"
            },
            "type": {
              "const": "runStarted",
              "title": "RunStartedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "runtime_id",
            "mode",
            "task"
          ],
          "title": "RunStartedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "external_session_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "sessionResolved",
              "title": "SessionResolvedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "SessionResolvedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "const": "outputTextDelta",
              "title": "OutputTextDeltaThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "title": "OutputTextDeltaThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "const": "reasoningDelta",
              "title": "ReasoningDeltaThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "text"
          ],
          "title": "ReasoningDeltaThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "plan": {
              "type": "string"
            },
            "type": {
              "const": "planUpdated",
              "title": "PlanUpdatedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "plan"
          ],
          "title": "PlanUpdatedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "request": {
              "$ref": "#/$defs/ThreadExternalAgentPermissionRequest"
            },
            "type": {
              "const": "permissionRequested",
              "title": "PermissionRequestedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "request"
          ],
          "title": "PermissionRequestedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "description": "Audit notification emitted once a previously-surfaced permission request\nreaches a terminal decision, whether answered by the client, denied by\ndefault on timeout, or otherwise resolved by the server.",
          "properties": {
            "decision": {
              "$ref": "#/$defs/ThreadExternalAgentPermissionOption"
            },
            "requestId": {
              "type": "string"
            },
            "resolution": {
              "$ref": "#/$defs/ThreadExternalAgentPermissionResolution"
            },
            "type": {
              "const": "permissionResolved",
              "title": "PermissionResolvedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "requestId",
            "decision",
            "resolution"
          ],
          "title": "PermissionResolvedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "proposal": true,
            "type": {
              "const": "proposedAction",
              "title": "ProposedActionThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "proposal"
          ],
          "title": "ProposedActionThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "const": "status",
              "title": "StatusThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "title": "StatusThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "description": "A durable artifact produced by a cloud (hosted) external-agent run, such\nas a pull request, patch bundle, or log URL.",
          "properties": {
            "artifact": {
              "$ref": "#/$defs/ThreadExternalAgentCloudArtifact"
            },
            "type": {
              "const": "cloudArtifact",
              "title": "CloudArtifactThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "artifact"
          ],
          "title": "CloudArtifactThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "description": "Lifecycle transition for a cloud (hosted) external-agent run.",
          "properties": {
            "message": {
              "type": [
                "string",
                "null"
              ]
            },
            "state": {
              "$ref": "#/$defs/ThreadExternalAgentCloudState"
            },
            "type": {
              "const": "cloudStatus",
              "title": "CloudStatusThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "state"
          ],
          "title": "CloudStatusThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "summary": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "completed",
              "title": "CompletedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "CompletedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "const": "failed",
              "title": "FailedThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "title": "FailedThreadExternalAgentEvent",
          "type": "object"
        },
        {
          "properties": {
            "reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "cancelled",
              "title": "CancelledThreadExternalAgentEventType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "CancelledThreadExternalAgentEvent",
          "type": "object"
        }
      ]
    },
    "ThreadExternalAgentMode": {
      "enum": [
        "plan",
        "propose"
      ],
      "type": "string"
    },
    "ThreadExternalAgentPermissionOption": {
      "enum": [
        "allowOnce",
        "rejectOnce"
      ],
      "type": "string"
    },
    "ThreadExternalAgentPermissionRequest": {
      "properties": {
        "action": true,
        "id": {
          "type": "string"
        },
        "options": {
          "items": {
            "$ref": "#/$defs/ThreadExternalAgentPermissionOption"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "action",
        "options"
      ],
      "type": "object"
    },
    "ThreadExternalAgentPermissionResolution": {
      "description": "How a surfaced external-agent permission request was ultimately resolved.\n\nIncluded in [`ThreadExternalAgentEvent::PermissionResolved`] so clients can\nkeep an audit trail that distinguishes an explicit client decision from a\nserver-applied default-deny.",
      "oneOf": [
        {
          "const": "client",
          "description": "The client answered the request via `thread/externalAgent/permission/respond`.",
          "type": "string"
        },
        {
          "const": "timedOut",
          "description": "No response arrived before the server-side timeout elapsed; denied by default.",
          "type": "string"
        },
        {
          "const": "defaultDenied",
          "description": "The request could not be parked for a response (e.g. the run is gone) and\nwas denied by default.",
          "type": "string"
        },
        {
          "const": "superseded",
          "description": "The run was cancelled, or a newer request replaced this one, before a\ndecision was made; denied by default.",
          "type": "string"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "event": {
      "$ref": "#/$defs/ThreadExternalAgentEvent"
    },
    "runId": {
      "type": "string"
    },
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "threadId",
    "runId",
    "event"
  ],
  "title": "ThreadExternalAgentEventNotification",
  "type": "object"
}