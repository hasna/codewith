{
  "$defs": {
    "ThreadScheduleIntervalUnit": {
      "enum": [
        "minutes",
        "hours",
        "days"
      ],
      "type": "string"
    },
    "ThreadSchedulePromptSource": {
      "enum": [
        "inline",
        "default"
      ],
      "type": "string"
    },
    "ThreadScheduleSpec": {
      "oneOf": [
        {
          "properties": {
            "type": {
              "const": "once",
              "title": "OnceThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "OnceThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "const": "dynamic",
              "title": "DynamicThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "DynamicThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "amount": {
              "format": "int64",
              "type": "integer"
            },
            "type": {
              "const": "interval",
              "title": "IntervalThreadScheduleSpecType",
              "type": "string"
            },
            "unit": {
              "$ref": "#/$defs/ThreadScheduleIntervalUnit"
            }
          },
          "required": [
            "type",
            "amount",
            "unit"
          ],
          "title": "IntervalThreadScheduleSpec",
          "type": "object"
        },
        {
          "properties": {
            "expression": {
              "type": "string"
            },
            "type": {
              "const": "cron",
              "title": "CronThreadScheduleSpecType",
              "type": "string"
            }
          },
          "required": [
            "type",
            "expression"
          ],
          "title": "CronThreadScheduleSpec",
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "expiresAt": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "nextRunAt": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "parentScheduleId": {
      "type": [
        "string",
        "null"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "promptSource": {
      "anyOf": [
        {
          "$ref": "#/$defs/ThreadSchedulePromptSource"
        },
        {
          "type": "null"
        }
      ]
    },
    "schedule": {
      "$ref": "#/$defs/ThreadScheduleSpec"
    },
    "threadId": {
      "type": "string"
    },
    "timezone": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "threadId",
    "prompt",
    "schedule"
  ],
  "title": "ThreadScheduleCreateParams",
  "type": "object"
}