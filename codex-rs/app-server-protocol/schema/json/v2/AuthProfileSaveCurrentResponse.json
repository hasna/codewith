{
  "$defs": {
    "AuthMode": {
      "description": "Authentication mode for OpenAI-backed providers.",
      "oneOf": [
        {
          "const": "apikey",
          "description": "OpenAI API key provided by the caller and stored by Codewith.",
          "type": "string"
        },
        {
          "const": "chatgpt",
          "description": "ChatGPT OAuth managed by Codewith (tokens persisted and refreshed by Codewith).",
          "type": "string"
        },
        {
          "const": "chatgptAuthTokens",
          "description": "[UNSTABLE] FOR OPENAI INTERNAL USE ONLY - DO NOT USE.\n\nChatGPT auth tokens are supplied by an external host app and are only\nstored in memory. Token refresh must be handled by the external host app.",
          "type": "string"
        },
        {
          "const": "agentIdentity",
          "description": "Programmatic Codewith auth backed by a registered Agent Identity.",
          "type": "string"
        },
        {
          "const": "personalAccessToken",
          "description": "Programmatic Codex auth backed by a personal access token.",
          "type": "string"
        }
      ]
    },
    "AuthProfileSubscriptionProvider": {
      "enum": [
        "chatgpt",
        "claudeAi",
        "cursor",
        "grok"
      ],
      "type": "string"
    },
    "AuthProfileSummary": {
      "properties": {
        "accountId": {
          "type": [
            "string",
            "null"
          ]
        },
        "active": {
          "type": "boolean"
        },
        "authMode": {
          "anyOf": [
            {
              "$ref": "#/$defs/AuthMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "email": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "plan": {
          "type": [
            "string",
            "null"
          ]
        },
        "subscriptionProvider": {
          "$ref": "#/$defs/AuthProfileSubscriptionProvider"
        }
      },
      "required": [
        "name",
        "subscriptionProvider",
        "active"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "profile": {
      "$ref": "#/$defs/AuthProfileSummary"
    }
  },
  "required": [
    "profile"
  ],
  "title": "AuthProfileSaveCurrentResponse",
  "type": "object"
}