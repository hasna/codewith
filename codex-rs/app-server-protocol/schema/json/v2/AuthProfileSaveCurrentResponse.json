{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AuthMode": {
      "description": "Authentication mode for OpenAI-backed providers.",
      "oneOf": [
        {
          "description": "OpenAI API key provided by the caller and stored by Codewith.",
          "enum": [
            "apikey"
          ],
          "type": "string"
        },
        {
          "description": "ChatGPT OAuth managed by Codewith (tokens persisted and refreshed by Codewith).",
          "enum": [
            "chatgpt"
          ],
          "type": "string"
        },
        {
          "description": "[UNSTABLE] FOR OPENAI INTERNAL USE ONLY - DO NOT USE.\n\nChatGPT auth tokens are supplied by an external host app and are only stored in memory. Token refresh must be handled by the external host app.",
          "enum": [
            "chatgptAuthTokens"
          ],
          "type": "string"
        },
        {
          "description": "Programmatic Codewith auth backed by a registered Agent Identity.",
          "enum": [
            "agentIdentity"
          ],
          "type": "string"
        },
        {
          "description": "Programmatic Codex auth backed by a personal access token.",
          "enum": [
            "personalAccessToken"
          ],
          "type": "string"
        }
      ]
    },
    "AuthProfileSubscriptionProvider": {
      "enum": [
        "chatgpt",
        "claudeAi",
        "cursor",
        "grok"
      ],
      "type": "string"
    },
    "AuthProfileSummary": {
      "properties": {
        "accountId": {
          "type": [
            "string",
            "null"
          ]
        },
        "active": {
          "type": "boolean"
        },
        "authMode": {
          "anyOf": [
            {
              "$ref": "#/definitions/AuthMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "email": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "plan": {
          "type": [
            "string",
            "null"
          ]
        },
        "subscriptionProvider": {
          "$ref": "#/definitions/AuthProfileSubscriptionProvider"
        }
      },
      "required": [
        "active",
        "name",
        "subscriptionProvider"
      ],
      "type": "object"
    }
  },
  "properties": {
    "profile": {
      "$ref": "#/definitions/AuthProfileSummary"
    }
  },
  "required": [
    "profile"
  ],
  "title": "AuthProfileSaveCurrentResponse",
  "type": "object"
}