  "properties": {
    "worktree": {
      "anyOf": [
        {
          "$ref": "#/$defs/Worktree"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "title": "WorktreeDetachResponse",
  "type": "object"
}