        "ownerThreadId": {
          "type": [
            "string",
            "null"
          ]
        },
        "releasedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "statusSnapshot": true,
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "worktreeId": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        }
      },
      "required": [
        "worktreeId",
        "mode",
        "lifecycleStatus",
        "baseRepoPath",
        "worktreePath",
        "statusSnapshot",
        "dirty",
        "cleanupPolicy",
        "forceDeleteRequested",
        "ownerKind",
        "createdAt",
        "updatedAt"
      ],
      "type": "object"
    },
    "WorktreeCleanupPolicy": {
      "enum": [
        "retain",
        "deleteIfClean",
        "forceDelete"
      ],
      "type": "string"
    },
    "WorktreeLifecycleStatus": {
      "enum": [
        "active",
        "cleanupPending",
        "released",
        "deleted"
      ],
      "type": "string"
    },
    "WorktreeMode": {
      "enum": [
        "isolatedWorktree",
        "sharedRepository"
      ],
      "type": "string"
    },
    "WorktreeOwnerKind": {
      "enum": [
        "manual",
        "mainSession",
        "subSession",
        "backgroundAgent"
      ],
      "type": "string"
