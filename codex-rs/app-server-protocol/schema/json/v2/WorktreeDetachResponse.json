            "string",
            "null"
          ]
        },
        "baseRepoPath": {
          "type": "string"
        },
        "baseSha": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "cleanupAfter": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "cleanupPolicy": {
          "$ref": "#/$defs/WorktreeCleanupPolicy"
        },
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "deletedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "dirty": {
          "type": "boolean"
        },
        "forceDeleteRequested": {
          "type": "boolean"
        },
        "headSha": {
          "type": [
            "string",
            "null"
          ]
        },
        "identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "lifecycleStatus": {
          "$ref": "#/$defs/WorktreeLifecycleStatus"
        },
        "mode": {
          "$ref": "#/$defs/WorktreeMode"
        },
        "ownerAgentRunId": {
          "type": [
            "string",
            "null"
          ]
        },
        "ownerKind": {
          "$ref": "#/$defs/WorktreeOwnerKind"
