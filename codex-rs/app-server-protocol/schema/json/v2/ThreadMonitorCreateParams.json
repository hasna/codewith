{
  "$defs": {
    "ThreadMonitorRouting": {
      "enum": [
        "stream",
        "file",
        "both"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "command": {
      "type": "string"
    },
    "cwd": {
      "description": "Optional working directory relative to the thread cwd. Parent directory\ntraversal and absolute paths are rejected.",
      "type": [
        "string",
        "null"
      ]
    },
    "name": {
      "type": "string"
    },
    "outputFile": {
      "description": "Optional output file relative to the monitor cwd. Parent directory\ntraversal, absolute paths, and symlink targets are rejected.",
      "type": [
        "string",
        "null"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "routing": {
      "anyOf": [
        {
          "$ref": "#/$defs/ThreadMonitorRouting"
        },
        {
          "type": "null"
        }
      ]
    },
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "threadId",
    "name",
    "prompt",
    "command"
  ],
  "title": "ThreadMonitorCreateParams",
  "type": "object"
}