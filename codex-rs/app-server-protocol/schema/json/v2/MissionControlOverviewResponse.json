        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "nodeId",
        "planId",
        "threadId",
        "assignedThreadId",
        "key",
        "sequence",
        "priority",
        "objective",
        "status",
        "ready",
        "tokensUsed",
        "timeUsedSeconds",
        "dependsOn",
        "createdAt",
        "updatedAt"
      ],
