{
  "$defs": {
    "AbsolutePathBuf": {
      "description": "A path that is guaranteed to be absolute and normalized (though it is not\nguaranteed to be canonicalized or exist on the filesystem).\n\nIMPORTANT: When deserializing an `AbsolutePathBuf`, a base path must be set\nusing [AbsolutePathBufGuard::new]. If no base path is set, the\ndeserialization will fail unless the path being deserialized is already\nabsolute.",
      "type": "string"
    },
    "ActiveSessionCapability": {
      "enum": [
        "receiveMessage",
        "queueMessage",
        "triggerTurn",
        "claudeChannelBridge"
      ],
      "type": "string"
    },
    "ActiveSessionPeerKind": {
      "enum": [
        "codewithSession",
        "spawnedAgent",
        "bridgeAdapter"
      ],
      "type": "string"
    },
    "AuthProfileKind": {
      "oneOf": [
        {
          "const": "unknown",
          "description": "The source did not record auth profile selection.",
          "type": "string"
        },
        {
          "const": "default",
          "description": "The default root auth profile was selected explicitly or by runtime default.",
          "type": "string"
        },
        {
          "const": "named",
          "description": "A named auth profile was selected.",
          "type": "string"
        }
      ]
    },
    "LocalSession": {
      "properties": {
        "accountLabel": {
          "default": null,
          "description": "Redacted account label for the selected auth profile, when available.",
          "type": [
            "string",
            "null"
          ]
        },
        "activeFlags": {
          "description": "Active-status flags from the thread runtime. Empty for non-active\nsessions.",
          "items": {
            "$ref": "#/$defs/ThreadActiveFlag"
          },
          "type": "array"
        },
        "agentPath": {
          "type": [
            "string",
            "null"
          ]
        },
        "authProfile": {
          "default": null,
          "description": "Auth profile selected for model requests in this session, if known.",
          "type": [
            "string",
            "null"
          ]
        },
        "authProfileKind": {
          "$ref": "#/$defs/AuthProfileKind",
          "default": "unknown",
          "description": "Whether `authProfile` is unknown, the default root profile, or a named profile."
        },
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "cwd": {
          "$ref": "#/$defs/AbsolutePathBuf"
        },
        "displayName": {
          "type": [
            "string",
            "null"
          ]
        },
        "gitInfo": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalSessionGitInfo"
            },
            {
              "type": "null"
            }
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "modelProvider": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "peer": {
          "anyOf": [
            {
              "$ref": "#/$defs/LocalSessionPeer"
            },
            {
              "type": "null"
            }
          ],
          "description": "Live active-session routing metadata when this record can receive\nin-memory activeSession/send traffic."
        },
        "redactions": {
          "items": {
            "$ref": "#/$defs/LocalSessionRedaction"
          },
          "type": "array"
        },
        "runtimeSessionId": {
          "description": "Live session instance id when known. Persisted-only records return null\nbecause a durable thread id is not the same as a runtime session id.",
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "$ref": "#/$defs/SessionSource"
        },
        "status": {
          "$ref": "#/$defs/LocalSessionStatus"
        },
        "threadId": {
          "description": "Durable Codewith thread id for the session record.",
          "type": "string"
        },
        "threadSource": {
          "anyOf": [
            {
              "$ref": "#/$defs/ThreadSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "threadId",
        "status",
        "activeFlags",
        "cwd",
        "modelProvider",
        "source",
        "createdAt",
        "updatedAt",
        "redactions"
      ],
      "type": "object"
    },
    "LocalSessionGitInfo": {
      "properties": {
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "LocalSessionPeer": {
      "properties": {
        "capabilities": {
          "items": {
            "$ref": "#/$defs/ActiveSessionCapability"
          },
          "type": "array"
        },
        "kind": {
          "$ref": "#/$defs/ActiveSessionPeerKind"
        },
        "lastSeenAt": {
          "format": "int64",
          "type": "integer"
        },
        "peerId": {
          "type": "string"
        }
      },
      "required": [
        "peerId",
        "kind",
        "capabilities",
        "lastSeenAt"
      ],
      "type": "object"
    },
    "LocalSessionRedaction": {
      "enum": [
        "gitOriginUrl",
        "processDetails"
      ],
      "type": "string"
    },
    "LocalSessionStatus": {
      "enum": [
        "active",
        "idle",
        "systemError",
        "closing",
        "loadedWithoutActivePeer",
        "notLoaded"
      ],
      "type": "string"
    },
    "MissionControlCapabilities": {
      "properties": {
        "durableMailbox": {
          "type": "boolean"
        },
        "filesystemMutation": {
          "type": "boolean"
        },
        "goals": {
          "type": "boolean"
        },
        "localSessions": {
          "type": "boolean"
        },
        "pendingInteractions": {
          "type": "boolean"
        },
        "remoteDispatch": {
          "type": "boolean"
        },
        "scheduledTasks": {
          "type": "boolean"
        },
        "shellExecution": {
          "type": "boolean"
        },
        "workflowMutation": {
          "type": "boolean"
        }
      },
      "required": [
        "localSessions",
        "durableMailbox",
        "pendingInteractions",
        "goals",
        "scheduledTasks",
        "remoteDispatch",
        "workflowMutation",
        "shellExecution",
        "filesystemMutation"
      ],
      "type": "object"
    },
    "MissionControlSession": {
      "properties": {
        "goal": {
          "anyOf": [
            {
              "$ref": "#/$defs/ThreadGoal"
            },
            {
              "type": "null"
            }
          ]
        },
        "goalPlans": {
          "items": {
            "$ref": "#/$defs/ThreadGoalPlan"
          },
          "type": "array"
        },
        "schedules": {
          "items": {
            "$ref": "#/$defs/ThreadSchedule"
          },
          "type": "array"
        },
        "session": {
          "$ref": "#/$defs/LocalSession"
        }
      },
      "required": [
        "session",
        "goalPlans",
        "schedules"
      ],
      "type": "object"
    },
    "SessionSource": {
      "oneOf": [
        {
          "enum": [
            "cli",
            "vscode",
            "exec",
            "appServer",
            "unknown"
          ],
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "custom": {
              "type": "string"
            }
          },
          "required": [
            "custom"
          ],
          "title": "CustomSessionSource",
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "subAgent": {
              "$ref": "#/$defs/SubAgentSource"
            }
          },
          "required": [
            "subAgent"
          ],
          "title": "SubAgentSessionSource",
          "type": "object"
        }
      ]
    },
    "SubAgentSource": {
      "oneOf": [
        {
          "enum": [
            "review",
            "compact",
            "memory_consolidation"
          ],
          "type": "string"
        },
        {
          "additionalProperties": false,
          "properties": {
            "thread_spawn": {
              "properties": {
                "agent_nickname": {
                  "default": null,
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "agent_path": {
                  "default": null,
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "agent_role": {
                  "default": null,
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "depth": {
                  "format": "int32",
                  "type": "integer"
                },
                "parent_thread_id": {
                  "$ref": "#/$defs/ThreadId"
                }
              },
              "required": [
                "parent_thread_id",
                "depth"
              ],
              "type": "object"
            }
          },
          "required": [
            "thread_spawn"
          ],
          "title": "ThreadSpawnSubAgentSource",
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "other": {
              "type": "string"
            }
          },
          "required": [
            "other"
          ],
          "title": "OtherSubAgentSource",
          "type": "object"
        }
      ]
    },
    "ThreadActiveFlag": {
      "enum": [
        "waitingOnApproval",
        "waitingOnUserInput"
      ],
      "type": "string"
    },
    "ThreadGoal": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "goalId": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ThreadGoalStatus"
        },
        "threadId": {
          "type": "string"
        },
        "timeUsedSeconds": {
          "format": "int64",
          "type": "integer"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "tokenBudget": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "tokensUsed": {
          "format": "int64",
          "type": "integer"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "threadId",
        "goalId",
        "objective",
        "status",
        "tokensUsed",
        "timeUsedSeconds",
        "createdAt",
        "updatedAt"
      ],
      "type": "object"
    },
    "ThreadGoalPlan": {
      "properties": {
        "activeNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "autoExecute": {
          "$ref": "#/$defs/ThreadGoalPlanAutoExecute"
        },
        "blockedNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "budgetLimitedNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "cancelledNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "completedNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "deferredNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "maxTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "nodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/ThreadGoalPlanNode"
          },
          "type": "array"
        },
        "pausedNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "pendingNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "planId": {
          "type": "string"
        },
        "readyNodeCount": {
          "format": "int64",
          "type": "integer"
        },
        "remainingTokens": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "status": {
          "$ref": "#/$defs/ThreadGoalPlanStatus"
        },
        "threadId": {
          "type": "string"
        },
        "totalTimeUsedSeconds": {
          "format": "int64",
          "type": "integer"
        },
        "totalTokensUsed": {
          "format": "int64",
          "type": "integer"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "usageLimitedNodeCount": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "planId",
        "threadId",
        "status",
        "autoExecute",
        "totalTokensUsed",
        "totalTimeUsedSeconds",
        "nodeCount",
        "completedNodeCount",
        "readyNodeCount",
        "activeNodeCount",
        "pendingNodeCount",
        "pausedNodeCount",
        "blockedNodeCount",
        "usageLimitedNodeCount",
        "budgetLimitedNodeCount",
        "deferredNodeCount",
        "cancelledNodeCount",
        "createdAt",
        "updatedAt",
        "nodes"
      ],
      "type": "object"
    },
    "ThreadGoalPlanAutoExecute": {
      "enum": [
        "off",
        "readyOnly",
        "aiDirected"
      ],
      "type": "string"
    },
